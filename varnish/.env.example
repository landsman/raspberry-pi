VARNISH_SIZE=512m
VARNISH_PURGE_TOKEN=changeme

# Separate token for internal services (CMS etc.) — PURGE only, no BAN
VARNISH_PURGE_TOKEN_CMS=changeme-cms

# Comma-separated list of IPs allowed to send PURGE/BAN requests.
# Supports IPv4 and IPv6, single value or multiple.
VARNISH_PURGE_IPS=192.0.2.1,2001:db8::1,192.0.2.2

# Enable debug mode — exposes X-Cache, X-Varnish, Via, Age, Server headers in responses.
# Set to true on staging/local, leave unset or false in production.
VARNISH_DEBUG=false
