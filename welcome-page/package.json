    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-plugin": "^1.167.22",
